}
void Dijkstra(int s, int t)
{
    int d[MAX];
    int truoc[MAX];
    bool visited[MAX];

    for(int i = 0; i < MAX; i++)
    {
        d[i] = INF;
        truoc[i] = -1;
        visited[i] = false;
    }

    d[s] = 0;

    for(int i = 0; i < MAX; i++)
    {
        int u = -1;
        int Min = INF;
         for(int j = 0; j < MAX; j++)
        {
            if(!visited[j] && d[j] < Min)
            {
                Min = d[j];
                u = j;
            }
        }

        if(u == -1)
            break;

        visited[u] = true;
         for(int v = 0; v < MAX; v++)
        {
            if(a[u][v] != 0 && !visited[v])
            {
                if(d[v] >= d[u] + a[u][v])
                {
                    d[v] = d[u] + a[u][v];
                    truoc[v] = u;
                }
            }
        }
    }

    if(d[t] == INF)
    {
        cout << "\nKhong co duong di!\n";
        return;
    }
  int path[MAX];
    int dem = 0
    int x = t;

    while(x != -1)
    {
        path[dem++] = x;
        x = truoc[x];
    }

    cout << "\nDuong di ngan nhat:\n";

    for(int i = dem - 1; i >= 0; i--)
    {
        cout << path[i] << "(" << TenTinh[path[i]] << ")";
        if(i != 0)
            cout << " -> ";
    }
   cout << "\nTong trong so: " << d[t] << endl;
}
void Prim(int start)
{
    bool visited[MAX];
    int T[MAX][MAX];
    int tong = 0;

    for(int i = 0; i < MAX; i++)
    {
        visited[i] = false;
        for(int j = 0; j < MAX; j++)
            T[i][j] = 0;
    }

    visited[start] = true;

    cout << "\nCac canh cua cay khung Prim:\n";

    for(int k = 0; k < MAX - 1; k++)
    {
        int Min = INF;
         int u = -1;
        int v = -1;

        for(int i = 0; i < MAX; i++)
        {
            if(visited[i])
            {
                for(int j = 0; j < MAX; j++)
                {
                    if(!visited[j] && a[i][j] != 0)
                    {
                        if(a[i][j] < Min)
                        {
                            Min = a[i][j];
                            u = i;
                            v = j;
                        }
                                            }
                }
            }
        }

        if(u == -1)
            break;

        visited[v] = true;
        T[u][v] = a[u][v];
        T[v][u] = a[v][u];
        tong += a[u][v];

        cout << TenTinh[u]
             << " - "
             << TenTinh[v]
             << " : "
             << a[u][v]
             << endl;
    }

    cout << "\nTong trong so cay khung = " << tong << endl;

    cout << "\nMa tran ke cua cay khung Prim\n\n";

    for(int i = 0; i < MAX; i++)
    {
        for(int j = 0; j < MAX; j++)
            cout << setw(3) << T[i][j];
        cout << endl;
    }
}
struct Edge
{
    int u;
    int v;
    int w;
};

Edge E[13]=
{
    {0,6,1},
    {6,7,2},
    {7,8,3},
    {8,0,4},
    {0,9,5},
    {0,10,6},
    {0,1,7},
    {0,2,8},
    {2,3,9},
    {3,4,10},
    {2,4,11},
    {4,5,12},
    {6,5,13}
};
int parent[MAX];

int Find(int x)
{
    if(parent[x]==x)
        return x;
    return Find(parent[x]);
}

void Union(int x,int y)
{
    parent[Find(x)] = Find(y);
}

void Kruskal()
{
    for(int i=0;i<MAX;i++)
        parent[i]=i;

    int T[MAX][MAX];
    int tong=0;
        for(int i=0;i<MAX;i++)
        for(int j=0;j<MAX;j++)
            T[i][j]=0;

    cout<<"\nCac canh cua cay khung Kruskal:\n";

    int dem=0;

    for(int i=0;i<13 && dem<MAX-1;i++)
    {
        int u=E[i].u;
        int v=E[i].v;

        if(Find(u)!=Find(v))
        {
            Union(u,v);

            T[u][v]=E[i].w;
            T[v][u]=E[i].w;

            tong+=E[i].w;
            dem++;
            cout<<TenTinh[u]
                <<" - "
                <<TenTinh[v]
                <<" : "
                <<E[i].w<<endl;
        }
    }

    cout<<"\nTong trong so cay khung = "<<tong<<endl;

    cout<<"\nMa tran ke cua cay khung Kruskal\n\n";

    for(int i=0;i<MAX;i++)
    {
        for(int j=0;j<MAX;j++)
            cout<<setw(3)<<T[i][j];
        cout<<endl;
    }
}
