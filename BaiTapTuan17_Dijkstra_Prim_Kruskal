int a[MAX][MAX];
void TaoDoThi()
{
    for(int i=0;i<MAX;i++)
        for(int j=0;j<MAX;j++)
            a[i][j]=0;

    a[0][6]=a[6][0]=1;     // D1
    a[6][7]=a[7][6]=2;     // D2
    a[7][8]=a[8][7]=3;     // D3
    a[8][0]=a[0][8]=4;     // D4
    a[0][9]=a[9][0]=5;     // D5
    a[0][10]=a[10][0]=6;   // D6
    a[0][1]=a[1][0]=7;     // D7
    a[0][2]=a[2][0]=8;     // D8
