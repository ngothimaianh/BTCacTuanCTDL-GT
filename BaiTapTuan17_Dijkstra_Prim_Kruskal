const int MAX = 11;
const int INF = 1000000;

string TenTinh[MAX] =
{
    "Ha Noi",
    "Thai Nguyen",
    "Bac Ninh",
    "Bac Giang",
    "Uong Bi",
    "Hai Phong",
    "Hai Duong",
    "Hung Yen",
    "Phu Ly",
    "Hoa Binh",
    "Son Tay"
};
int a[MAX][MAX];
void TaoDoThi()
{
    for(int i=0;i<MAX;i++)
        for(int j=0;j<MAX;j++)
            a[i][j]=0;

    a[0][6]=a[6][0]=1;     // D1
    a[6][7]=a[7][6]=2;     // D2
    a[7][8]=a[8][7]=3;     // D3
    a[8][0]=a[0][8]=4;     // D4
    a[0][9]=a[9][0]=5;     // D5
    a[0][10]=a[10][0]=6;   // D6
    a[0][1]=a[1][0]=7;     // D7
    a[0][2]=a[2][0]=8;     // D8
    a[2][3]=a[3][2]=9;     // D9
    a[3][4]=a[4][3]=10;    // D10
    a[2][4]=a[4][2]=11;    // D11
    a[4][5]=a[5][4]=12;    // D12
    a[6][5]=a[5][6]=13;    // D13
}
void InTenDinh()
{
    cout << "\nDanh sach cac dinh\n";

    for(int i=0;i<MAX;i++)
        cout << i << " : " << TenTinh[i] << endl;
}
void InMaTran()
{
    cout << "\nMa tran ke\n\n";

    for(int i=0;i<MAX;i++)
    {
        for(int j=0;j<MAX;j++)
            cout << setw(3) << a[i][j];
        cout << endl;
    }
}
void Dijkstra(int s, int t)
{
    int d[MAX];
    int truoc[MAX];
    bool visited[MAX];

    for(int i = 0; i < MAX; i++)
    {
        d[i] = INF;
        truoc[i] = -1;
        visited[i] = false;
    }

    d[s] = 0;

    for(int i = 0; i < MAX; i++)
    {
        int u = -1;
        int Min = INF;
         for(int j = 0; j < MAX; j++)
        {
            if(!visited[j] && d[j] < Min)
            {
                Min = d[j];
                u = j;
            }
        }

        if(u == -1)
            break;

        visited[u] = true;
         for(int v = 0; v < MAX; v++)
        {
            if(a[u][v] != 0 && !visited[v])
            {
                if(d[v] >= d[u] + a[u][v])
                {
                    d[v] = d[u] + a[u][v];
                    truoc[v] = u;
                }
            }
        }
    }

    if(d[t] == INF)
    {
        cout << "\nKhong co duong di!\n";
        return;
    }
  int path[MAX];
    int dem = 0
    int x = t;

    while(x != -1)
    {
        path[dem++] = x;
        x = truoc[x];
    }

    cout << "\nDuong di ngan nhat:\n";

    for(int i = dem - 1; i >= 0; i--)
    {
        cout << path[i] << "(" << TenTinh[path[i]] << ")";
        if(i != 0)
            cout << " -> ";
    }
   cout << "\nTong trong so: " << d[t] << endl;
}